# =========================
# Core API (root)
# =========================
PORT=3000
CONFIG_DIR=.
CORE_CONFIG_DIR=.core-config
CORE_ENV=dev
CORE_FINGERPRINT_PREFIX=

# Optional request auth for core API
CORE_API_KEY=

# LLM provider keys (at least one)
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# =========================
# Switchboard auth (simple Google mode)
# =========================
SWITCHBOARD_RBAC_ENABLED=true
SWITCHBOARD_AUTH_GOOGLE_ENABLED=true
SWITCHBOARD_AUTH_GOOGLE_CLIENT_ID=
# Only this email gets admin-tecnico (sees all). Comma-separated.
SWITCHBOARD_ADMIN_EMAILS=alvaro.e.mur@gmail.com
# Google users as operador for one account: email:accountId (e.g. alvaro@inspiro:gateway)
SWITCHBOARD_GOOGLE_OPERADORES=alvaro@inspiro:gateway
SWITCHBOARD_AUTH_GOOGLE_ALLOWED_HOSTED_DOMAINS=
SWITCHBOARD_KEYS_PATH=./switchboard/data/core-keys.json

# =========================
# Optional advanced mode (Core-issued JWT)
# =========================
# CORE_AUTH_GOOGLE_ENABLED=true
# CORE_AUTH_GOOGLE_CLIENT_ID=
# CORE_AUTH_GOOGLE_CLIENT_SECRET=
# CORE_AUTH_GOOGLE_REDIRECT_URI=http://localhost:8888
# CORE_AUTH_JWT_SECRET=
# SWITCHBOARD_AUTH_JWT_ENABLED=true
# SWITCHBOARD_AUTH_JWT_SECRET=
