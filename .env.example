# =========================
# Core API (root)
# =========================
PORT=3000
CONFIG_DIR=.
CORE_CONFIG_DIR=.core-config
CORE_ENV=dev
CORE_FINGERPRINT_PREFIX=

# Optional request auth for core API
CORE_API_KEY=

# LLM provider keys (at least one)
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Use @mariozechner/pi-ai for LLM calls (PoC). Set to true/1 to enable; otherwise src/llm/core.js.
# USE_PI_AI=

# =========================
# Persistence (Neon Postgres)
# =========================
# Optional. If set, switchboard uses Neon instead of registry.json.
# Get connection string from https://console.neon.tech
# SWITCHBOARD_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
# CORE_ASSIGNMENT_HEALTHCHECK_TIMEOUT_MS=5000

# =========================
# Internal control-plane auth (RBAC + keys)
# =========================
SWITCHBOARD_RBAC_ENABLED=true
SWITCHBOARD_KEYS_PATH=./src/switchboard/data/core-keys.json

# =========================
# Optional user JWT mode for internal APIs
# =========================
# SWITCHBOARD_AUTH_JWT_ENABLED=true
# Force JWT-only auth (disables core-key fallback in RBAC)
# SWITCHBOARD_AUTH_JWT_ONLY=true
# JWT validation (issuer/audience required when JWT mode is enabled)
# SWITCHBOARD_AUTH_JWT_ISSUER=core-auth
# SWITCHBOARD_AUTH_JWT_AUDIENCE=core-switchboard
# Recommended (RS256/ES256): JWKS URL or inline JWKS JSON
# SWITCHBOARD_AUTH_JWT_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# SWITCHBOARD_AUTH_JWT_JWKS={"keys":[...]}
# Optional legacy mode (HS256 shared secret)
# SWITCHBOARD_AUTH_JWT_SECRET=

# =========================
# Google OAuth login + core-issued session JWT (for web/gateway)
# =========================
# CORE_AUTH_GOOGLE_ENABLED=true
# CORE_AUTH_GOOGLE_CLIENT_ID=
# CORE_AUTH_GOOGLE_CLIENT_SECRET=
# CORE_AUTH_GOOGLE_REDIRECT_URI=http://localhost:5173/
# CORE_AUTH_GOOGLE_SCOPES=openid,email,profile
# Master account(s) allowed to administrar RBAC users
# CORE_AUTH_MASTER_EMAILS=alvaro.e.mur@gmail.com
# Optional Google hosted-domain allowlist (comma-separated)
# CORE_AUTH_GOOGLE_ALLOWED_HOSTED_DOMAINS=example.com
# Legacy admin allowlist fallback (optional; prefer /core/auth/users)
# CORE_AUTH_GOOGLE_ADMIN_EMAILS=admin@example.com
# Dev-only escape hatch (avoid in production)
# CORE_AUTH_GOOGLE_ALLOW_ANY_ADMIN=false
# Enable legacy allowlist fallback behavior in login
# CORE_AUTH_LEGACY_EMAIL_ALLOWLIST_FALLBACK=false
# Optional accounts/workspaces scope injected into JWT claims
# CORE_AUTH_ADMIN_ALLOWED_ACCOUNTS=inspiro-agents,platform
# CORE_AUTH_DEFAULT_ACCOUNT_ID=inspiro-agents
# JWT issued by core after Google login
# CORE_AUTH_JWT_SECRET=change-me-super-secret
# CORE_AUTH_JWT_ISSUER=core-auth
# CORE_AUTH_JWT_AUDIENCE=core-switchboard
# CORE_AUTH_JWT_TTL_SEC=3600

# If using the core-issued HS256 JWT in switchboard auth, set:
# SWITCHBOARD_AUTH_JWT_ENABLED=true
# SWITCHBOARD_AUTH_JWT_ONLY=true
# SWITCHBOARD_AUTH_JWT_SECRET=change-me-super-secret
# SWITCHBOARD_AUTH_JWT_ISSUER=core-auth
# SWITCHBOARD_AUTH_JWT_AUDIENCE=core-switchboard
