# =========================
# Core API (root)
# =========================
PORT=3000
CONFIG_DIR=.
CORE_CONFIG_DIR=.core-config
CORE_ENV=dev
CORE_FINGERPRINT_PREFIX=

# Optional request auth for core API
CORE_API_KEY=

# LLM provider keys (at least one)
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# =========================
# Internal control-plane auth (RBAC + keys)
# =========================
SWITCHBOARD_RBAC_ENABLED=true
SWITCHBOARD_KEYS_PATH=./switchboard/data/core-keys.json

# =========================
# Optional user JWT mode for internal APIs
# =========================
# SWITCHBOARD_AUTH_JWT_ENABLED=true
# SWITCHBOARD_AUTH_JWT_SECRET=
# SWITCHBOARD_AUTH_JWT_ISSUER=core-auth
# SWITCHBOARD_AUTH_JWT_AUDIENCE=core-switchboard
